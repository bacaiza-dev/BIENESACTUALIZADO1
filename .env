# Configuración de Base de Datos
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=admin
DB_NAME=intbienes

# Configuración del Servidor
PORT=3000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Frontend URL
FRONTEND_URL=http://localhost:3001

# Configuración de CORS
CORS_ORIGIN=http://localhost:3001

# Configuración de Redis (si aplica)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Configuración de MinIO (si aplica)
MINIO_ENDPOINT=127.0.0.1
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Configuración de Email (opcional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=

# Configuración de la Aplicación
APP_VERSION=1.0.0
APP_NAME=Sistema de Gestión de Bienes INT

# Configuración de Logs
LOG_LEVEL=info

# Configuración de Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=15

# Configuración de Archivos
MAX_FILE_SIZE=5242880

# Configuración de AI (opcional)
AI_API_ENABLED=false
AI_API_KEY=
AI_API_ENDPOINT=

# Configuración de QR
QR_SECRET=default-qr-secret-key

# Configuración de VAPID (opcional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@bienesint.com