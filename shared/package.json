{
  "name": "intbienes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "vite --host",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/",
    "dev:full": "concurrently \"npm run dev\" \"npm run server:dev\"",
    "start": "node start.js",
    "server": "node server.js",
    "server:dev": "nodemon server.js",
    "server:init": "node scripts/init-system.js",
    "server:quick": "node quick-server.js",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "mobile:install": "npm install @capacitor/core @capacitor/cli @capacitor/android @capacitor/ios",
    "mobile:init": "npx cap init intbienes com.intbienes.app",
    "mobile:add": "npx cap add android && npx cap add ios",
    "mobile:build": "npm run build && npx cap sync",
    "mobile:android": "npx cap run android",
    "mobile:ios": "npx cap run ios",
    "mobile:sync": "npx cap sync",
    "mobile:open:android": "npx cap open android",
    "mobile:open:ios": "npx cap open ios",
    "mobile:serve": "npx cap serve",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "node scripts/test-api.js",
    "test:db": "node scripts/test-database.js",
    "test:endpoints": "node scripts/test-endpoints.js",
    "analyze": "vue-cli-service build --analyze",
    "setup": "node scripts/setup.js",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "db:configure": "node scripts/configurar-db.js",
    "migrate:node": "node scripts/ejecutar-migracion.js",
    "migrate:normalize": "mysql -u root -p intbienes < basededatos/migracion_normalizacion.sql",
    "migrate:verify": "node scripts/verificar-migracion.js",
    "data:load": "node scripts/cargar-datos.js",
    "data:load-all": "node scripts/cargar-todos-los-datos.js",
    "data:load-completos": "node scripts/cargar-datos-completos.js",
    "data:analyze": "node scripts/analizar-detallado.js",
    "data:load-corregidos": "node scripts/cargar-datos-corregidos.js",
    "data:insert-faltantes": "node scripts/insertar-faltantes.js",
    "firebase:init": "firebase init",
    "firebase:deploy": "firebase deploy",
    "firebase:serve": "firebase serve"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.8",
    "@capacitor/app": "^5.0.0",
    "@capacitor/camera": "^5.0.10",
    "@capacitor/cli": "^7.4.1",
    "@capacitor/core": "^5.7.8",
    "@capacitor/device": "^5.0.8",
    "@capacitor/filesystem": "^5.2.2",
    "@capacitor/haptics": "^5.0.8",
    "@capacitor/ios": "^5.7.8",
    "@capacitor/keyboard": "^5.0.9",
    "@capacitor/network": "^5.0.8",
    "@capacitor/preferences": "^5.0.8",
    "@capacitor/status-bar": "^5.0.8",
    "@vueuse/components": "^11.2.0",
    "@vueuse/core": "^11.2.0",
    "axios": "^1.7.8",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.3",
    "bootstrap": "^5.3.3",
    "boxicons": "^2.1.4",
    "chart.js": "^4.5.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "firebase": "^10.14.1",
    "helmet": "^7.1.0",
    "idb": "^7.1.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "jsqr": "^1.4.0",
    "lodash-es": "^4.17.21",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.15.2",
    "pinia": "^3.0.3",
    "qrcode": "^1.5.4",
    "qrcode.vue": "^3.6.0",
    "qrcodejs2": "^0.0.2",
    "readline-sync": "^1.4.10",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "sweetalert2": "^11.14.5",
    "vue": "^3.2.13",
    "vue-chartjs": "^5.3.1",
    "vue-draggable-plus": "^0.5.3",
    "vue-i18n": "^10.0.4",
    "vue-multiselect": "^3.1.0",
    "vue-qrcode-reader": "^5.7.2",
    "vue-router": "^4.0.3",
    "vue-toastification": "^2.0.0-rc.5",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue3-perfect-scrollbar": "^2.0.0",
    "vuetify": "^3.7.4",
    "vuex": "^4.0.0",
    "workbox-webpack-plugin": "^7.1.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/eslint-config-prettier": "^9.0.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.0.1",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "firebase-tools": "^13.35.1",
    "nodemon": "^3.1.7",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es2022": true
    },
    "extends": [
      "plugin:vue/vue3-essential",
      "eslint:recommended",
      "@vue/eslint-config-prettier"
    ],
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "vue/multi-word-component-names": "off",
      "no-unused-vars": "warn"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "description": "Sistema de Gestión de Bienes Institucionales - Aplicación Híbrida",
  "main": ".eslintrc.js",
  "keywords": [
    "vue",
    "capacitor",
    "hybrid",
    "bienes",
    "institucionales"
  ],
  "author": "Instituto Nelson Torres",
  "license": "ISC"
}
